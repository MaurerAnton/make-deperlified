# Converted from word
description: "Test the word, words, wordlist, firstword, and lastword functions."
details: "Produce a variable with a large number of words in it, determine the number of words, and then read each one back."

[case]
makefile:

string  := word.pl general_test2.pl   FORCE.pl word.pl generic_test.perl MAKEFILES_variable.pl
string2 := $(string) $(string) $(string) $(string) $(string) $(string) $(string)
string3 := $(string2) $(string2) $(string2) $(string2) $(string2) $(string2) $(string2)
string4 := $(string3) $(string3) $(string3) $(string3) $(string3) $(string3) $(string3)
.RECIPEPREFIX = >
all:
> @echo $(words $(string))
> @echo $(words $(string4))
> @echo $(word 1, $(string))
> @echo $(word 100, $(string))
> @echo $(word 1  , $(string))
> @echo $(word 1000, $(string3))
> @echo $(word 9223372036854775807, $(string2))
> @echo $(wordlist 3, 4, $(string))
> @echo $(wordlist 4, 3, $(string))
> @echo $(wordlist 1 , 6  , $(string))
> @echo $(wordlist 5,7, $(string))
> @echo $(wordlist 100, 110, $(string))
> @echo $(wordlist 7, 10, $(string2))
> @echo $(wordlist 9223372036854775807, 0, $(string2))
answer:
6
2058
word.pl

word.pl


FORCE.pl word.pl

word.pl general_test2.pl FORCE.pl word.pl generic_test.perl MAKEFILES_variable.pl
generic_test.perl MAKEFILES_variable.pl

word.pl general_test2.pl FORCE.pl word.pl

[case]
makefile:
FOO = foo bar biz baz

word-e1: ; @echo $(word ,$(FOO))
word-e2: ; @echo $(word abc ,$(FOO))
word-e3: ; @echo $(word 1a,$(FOO))
word-e4: ; @echo $(word 9999999999999999999,$(FOO))

wordlist-e1: ; @echo $(wordlist ,,$(FOO))
wordlist-e2: ; @echo $(wordlist abc ,,$(FOO))
wordlist-e3: ; @echo $(wordlist 1, 12a ,$(FOO))
options: word-e1
answer: "#MAKEFILE#:3: *** invalid first argument to 'word' function: empty value.  Stop."
exit_code: 512

[case]
options: word-e2
answer: "#MAKEFILE#:4: *** invalid first argument to 'word' function: 'abc '.  Stop."
exit_code: 512

[case]
options: word-e3
answer: "#MAKEFILE#:5: *** invalid first argument to 'word' function: '1a'.  Stop."
exit_code: 512

[case]
options: word-e4
answer: "#MAKEFILE#:6: *** invalid first argument to 'word' function: '9999999999999999999' out of range.  Stop."
exit_code: 512

[case]
options: wordlist-e1
answer: "#MAKEFILE#:8: *** invalid first argument to 'wordlist' function: empty value.  Stop."
exit_code: 512

[case]
options: wordlist-e2
answer: "#MAKEFILE#:9: *** invalid first argument to 'wordlist' function: 'abc '.  Stop."
exit_code: 512

[case]
options: wordlist-e3
answer: "#MAKEFILE#:10: *** invalid second argument to 'wordlist' function: ' 12a '.  Stop."
exit_code: 512

[case]
makefile:
FOO = foo bar biz baz

W = $(word $x,$(FOO))
WL = $(wordlist $s,$e,$(FOO))

word-e: ; @echo $(W)
wordlist-e: ; @echo $(WL)
options: word-e x=
answer: "#MAKEFILE#:3: *** invalid first argument to 'word' function: empty value.  Stop."
exit_code: 512

[case]
options: word-e x=abc
answer: "#MAKEFILE#:3: *** invalid first argument to 'word' function: 'abc'.  Stop."
exit_code: 512

[case]
options: word-e x=0
answer: "#MAKEFILE#:3: *** first argument to 'word' function must be greater than 0.  Stop."
exit_code: 512

[case]
options: wordlist-e s= e=
answer: "#MAKEFILE#:4: *** invalid first argument to 'wordlist' function: empty value.  Stop."
exit_code: 512

[case]
options: wordlist-e s=abc e=
answer: "#MAKEFILE#:4: *** invalid first argument to 'wordlist' function: 'abc'.  Stop."
exit_code: 512

[case]
options: wordlist-e s=4 e=12a
answer: "#MAKEFILE#:4: *** invalid second argument to 'wordlist' function: '12a'.  Stop."
exit_code: 512

[case]
options: wordlist-e s=0 e=12
answer: "#MAKEFILE#:4: *** invalid first argument to 'wordlist' function: '0'.  Stop."
exit_code: 512

[case]
options: wordlist-e s=1 e=-1
answer: "#MAKEFILE#:4: *** invalid second argument to 'wordlist' function: '-1'.  Stop."
exit_code: 512

[case]
makefile:

void :=
list := $(void) foo bar baz #

a := $(word 1,$(list))
b := $(firstword $(list))

.PHONY: all

all: ; @test "$a" = "$b" && echo $a
answer: "foo"

[case]
makefile:

void :=
list := $(void) foo bar baz #

a := $(word $(words $(list)),$(list))
b := $(lastword $(list))

.PHONY: all

all: ; @test "$a" = "$b" && echo $a
answer: "baz"
