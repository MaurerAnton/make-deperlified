# Converted from shell
description: "Test the $(shell ...) function."

[case]
makefile:
.PHONY: all
OUT := $(shell echo hi)
all: ; @echo $(OUT)
              
answer: "hi"

[case]
makefile:
.PHONY: all
all: ; @echo $(shell echo hi)
              
answer: "hi"

[case]
makefile:
.PHONY: all
PRE := $(.SHELLSTATUS)
$(shell exit 0)
OK := $(.SHELLSTATUS)
$(shell exit 1)
BAD := $(.SHELLSTATUS)
all: ; @echo PRE=$(PRE) OK=$(OK) BAD=$(BAD)
              
answer: "PRE= OK=0 BAD=1"

[case]
makefile:

FOO := $(shell echo '#')
foo: ; echo '$(FOO)'
answer: "echo '#'
#"

[case]
makefile:

OUT = $(shell echo $$FOO)
foo: ; @echo '$(OUT)'
answer: "baz"

[case]
makefile:

FOO = bar
OUT = $(shell echo $$FOO)
foo: ; @echo '$(OUT)'
answer: "bar"

[case]
makefile:

export FOO = bar
OUT = $(shell echo $$FOO)
foo: ; @echo '$(OUT)'
answer: "bar"

[case]
makefile:

export HI := $(shell echo hi)
.PHONY: all
all: ; @echo $$HI
answer: "hi"

[case]
makefile:

export HI = $(shell echo hi)
.PHONY: all
all: ; @echo $$HI
answer: "hi"

[case]
makefile:

HI = $(shell echo hi)
.PHONY: all
all: ; @echo $$HI
answer: "hi"

[case]
makefile:

HI = $(shell echo hi)
bad := $(HI)
.PHONY: all
all: ; @echo $$HI $(bad)
answer: "hi hi"

[case]
makefile:

HI = $(shell echo hi)
export bad = $(HI)
.PHONY: all
all:; : $(HI)
answer: ": hi"

[case]
makefile:

export HI = $(shell echo $$HI)
.PHONY: all
all:; @echo $$HI
answer: "outer"

[case]
makefile:

export HI = $(shell echo $$HI)
.PHONY: all
all:; : $(HI)
answer: ": outer"

[case]
makefile:

.RECIPEPREFIX = >
all:
>@echo hi
>$(shell ./basdfdfsed there)
>@echo $(.SHELLSTATUS)
answer: "#MAKE#: ./basdfdfsed: No such file or directory
hi
127"

[case]
makefile:

$(shell ./basdfdfsed where)
all: ; @echo $(.SHELLSTATUS)
answer: "#MAKE#: ./basdfdfsed: No such file or directory
127"

[case]
makefile:
.PHONY: all
$(shell kill -2 $$$$)
STAT := $(.SHELLSTATUS)
all: ; @echo STAT=$(STAT)
              
answer: "STAT=130"

[case]
makefile:

out := $(shell bad-command 2>&1)
all: ; @echo '$(.SHELLSTATUS): $(out)'
answer: "127: not found"

[case]
makefile:

ifeq ($(ELT),)
default:; @$(MAKE) -f #MAKEFILE# ELT=1
else ifeq ($(ELT),1)
OUTPUT := $(shell $(MAKE) -f #MAKEFILE# ELT=2)
$(info $(OUTPUT))
default:;: $(ELT)
else
default:;: $(ELT)
endif
options: --no-print-directory -j2 --jobserver-style=pipe
answer: "#MAKE#[2]: warning: jobserver unavailable: using -j1 (add '+' to parent make rule)
: 2
: 1"

[case]
makefile:

export PATH = $(shell echo "tests:$$PATH")
foo = $(shell echo yes)

all:;echo $(foo)
answer: "echo yes
yes"

[case]
makefile:

SHELL:=/bin/bash
export $(shell echo hello)
all:; @echo $$
answer: "hello"
