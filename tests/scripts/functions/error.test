# Converted from error
description: "The following test creates a makefile to test the error function."

[case]
makefile:
err = $(error Error found)

ifdef ERROR1
$(error error is $(ERROR1))
endif

ifdef ERROR2
$(error error is $(ERROR2))
endif

ifdef ERROR3
all: some; @echo $(error error is $(ERROR3))
endif

ifdef ERROR4
all: some; @echo error is $(ERROR4)
#TAB#@echo $(error error is $(ERROR4))
endif

some: ; @echo Some stuff

testvar: ; @: $(err)
options: ERROR1=yes
answer: "#MAKEFILE#:4: *** error is yes.  Stop."
exit_code: 512

[case]
options: ERROR2=no
answer: "#MAKEFILE#:8: *** error is no.  Stop."
exit_code: 512

[case]
options: ERROR3=maybe
answer: "Some stuff
#MAKEFILE#:12: *** error is maybe.  Stop."
exit_code: 512

[case]
options: ERROR4=definitely
answer: "Some stuff
#MAKEFILE#:17: *** error is definitely.  Stop."
exit_code: 512

[case]
options: testvar
answer: "#MAKEFILE#:22: *** Error found.  Stop."
exit_code: 512
