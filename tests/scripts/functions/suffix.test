# Converted from suffix
description: "The following test creates a makefile to test the suffix function."
details: "The suffix function will return the string following the last _._ the list provided. It will provide all of the unique suffixes found in the list. The long strings are sorted to remove duplicates."

[case]
makefile:
string  := word.pl general_test2.pl1 FORCE.pl word.pl3 generic_test.perl /tmp.c/bar foo.baz/bar.c MAKEFILES_variable.c
string2 := $(string) $(string) $(string) $(string) $(string) $(string) $(string)
string3 := $(string2) $(string2) $(string2) $(string2) $(string2) $(string2) $(string2)
string4 := $(string3) $(string3) $(string3) $(string3) $(string3) $(string3) $(string3)
all: 
	@echo $(suffix $(string)) 
	@echo $(sort $(suffix $(string4))) 
	@echo $(suffix $(string) a.out) 
	@echo $(sort $(suffix $(string3))) 
answer: ".pl .pl1 .pl .pl3 .perl .c .c
.c .perl .pl .pl1 .pl3
.pl .pl1 .pl .pl3 .perl .c .c .out
.c .perl .pl .pl1 .pl3"
