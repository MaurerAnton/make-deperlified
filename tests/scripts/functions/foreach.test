# Converted from foreach
description: "Test the foreach function."
details: "This is a test of the foreach function in gnu make. This function starts with a space separated list of names and a variable. Each name in the list is substituted into the variable and the given text evaluated. The general form of the command is 1001 1001 1002foreach var,$list,$text). Several types of foreach loops are tested"

[case]
makefile:
space = ' '
null :=
auto_var = udef space CC null FOOFOO MAKE foo CFLAGS WHITE @ <
foo = bletch null @ garf
av = $(foreach var, $(auto_var), $(origin $(var)) )
override WHITE := BLACK
for_var = $(addsuffix .c,foo $(null) $(foo) $(space) $(av) )
fe = $(foreach var2, $(for_var),$(subst .c,.o, $(var2) ) )
all: auto for2
auto : ; @echo $(av)
for2: ; @echo $(fe)
options: -e WHITE=WHITE CFLAGS=
answer:
undefined file default file environment override default file command line override automatic automatic
foo.o bletch.o null.o @.o garf.o .o    .o undefined.o file.o default.o file.o environment.o override.o default.o file.o command.o line.o override.o automatic.o automatic.o

[case]
makefile:

.PHONY: all target
all: target

x := BAD

define mktarget
target: x := $(x)
target: ; @echo "$(x)"
endef

x := GLOBAL

$(foreach x,FOREACH,$(eval $(value mktarget)))
answer: "FOREACH"

[case]
makefile:

$(foreach \
  a \
, b c d \
, $(info $a))
all:;@:
answer:
b
c
d

[case]
makefile:

x = $(foreach ,1 2 3,a)
y := $x

all: ; @echo $y
answer: "a a a"

[case]
makefile:

x = $(foreach )
y = $x

all: ; @echo $y
answer: "#MAKEFILE#:2: *** insufficient number of arguments (1) to function 'foreach'.  Stop."
exit_code: 512

[case]
makefile:

x = $(foreach x,y)
y := $x

all: ; @echo $y
answer: "#MAKEFILE#:2: *** insufficient number of arguments (2) to function 'foreach'.  Stop."
exit_code: 512
