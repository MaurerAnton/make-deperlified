# Converted from wildcard
description: "The following test creates a makefile to test wildcard expansions and the ability to put a command on the same line as the target name separated by a semi-colon."
details: "This test creates 4 files by the names of 1.example, two.example and 3.example. We execute three tests. The first executes the print1 target which tests the '*' wildcard by echoing all filenames by the name of '*.example'. The second test echo's all files which match '?.example' and [a-z0-9].example. Lastly we clean up all of the files using the '*' wildcard as in the first test"

[setup]
touch: example.1 example.two example.3 example.for example._ xxx.yyy

[case]
makefile:

.PHONY: print1 print2 clean
print1: ;@echo $(wildcard example.*)
print2:
	@echo $(wildcard example.?)
	@echo $(wildcard example.[a-z0-9])
	@echo $(wildcard example.[!A-Za-z_\!])
clean:
	rm -f $(wildcard example.*)
options: print1
answer: "example.1 example.3 example._ example.for example.two"

[case]
options: print2
answer:
example.1 example.3 example._
example.1 example.3
example.1 example.3

[case]
options: clean
answer: "rm -f example.1 example.3 example._ example.for example.two"

[case]
makefile:

all: ; @echo $(wildcard xz--y*.7)

[case]
makefile:
exists: ; @echo file=$(wildcard xxx.yyy)
answer: "file=xxx.yyy"

[case]
makefile:
exists: ; @echo file=$(wildcard xxx.yyy)
answer: "file="

[case]
makefile:
print4: ; @echo $(wildcard /)
answer: "/"

[case]
makefile:
all: ; @echo $(wildcard __ldir*/.)
answer: "__ldir/."
