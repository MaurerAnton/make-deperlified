# Converted from substitution
description: "Test the subst and patsubst functions"

[case]
makefile:

foo := a.o b.o c.o
bar := $(foo:.o=.c)
bar2:= $(foo:%.o=%.c)
bar3:= $(patsubst %.c,%.o,x.c.c bar.c)
all:;@echo $(bar); echo $(bar2); echo $(bar3)
answer:
a.c b.c c.c
a.c b.c c.c
x.c.o bar.o

[case]
makefile:
all:;@echo $(patsubst Foo,Repl,FooFoo)
answer: "FooFoo"

[case]
makefile:

A := fooBARfooBARfoo
all:;@echo $(A:fooBARfoo=REPL)
answer: "fooBARREPL"
