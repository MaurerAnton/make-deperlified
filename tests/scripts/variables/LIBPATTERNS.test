# Converted from LIBPATTERNS
description: "Test .LIBPATTERNS special variable."

[setup]
touch: mtest_foo.a

[case]
makefile:

.LIBPATTERNS = mtest_%.a
all: -lfoo ; @echo "build $@ from $<"
answer: "build all from mtest_foo.a"

[case]
makefile:

.LIBPATTERNS = mtest_foo.a mtest_%.a
all: -lfoo ; @echo "build $@ from $<"
answer: "#MAKE#: .LIBPATTERNS element 'mtest_foo.a' is not a pattern
build all from mtest_foo.a"
