# Converted from private
description: "Test 'private' variables."

[case]
makefile:

a:
F = g
a: F = a
b: private F = b

a b c: ; @echo $@: F=$(F)
a: b
b: c
answer: "c: F=a
b: F=b
a: F=a"

[case]
options: b
answer: "c: F=g
b: F=b"

[case]
makefile:

t.a:

F1 = g
F2 = g
%.a: private F1 = a
%.a: F2 = a

t.a t.b: ; @echo $@: F1=$(F1) / F2=$(F2)
t.a: t.b
answer: "t.b: F1=g / F2=a
t.a: F1=a / F2=a"

[case]
makefile:

a:
private F = g
G := $(F)
a:
b: F = b

a b: ; @echo $@: F=$(F) / G=$(G)
a: b
answer: "b: F=b / G=g
a: F= / G=g"

[case]
makefile:

private export F = global
$(info $(shell #HELPER# env F))
a: b
b: export F=b
a b: ; @#HELPER# raw $@ env F
answer: "F=global
bF=b
aF=<unset>"

[case]
makefile:

_X = x
a: export override private _X = a
a: ; @echo _X=$(_X) / _X=$$_X
answer: "_X=a / _X=a"

[case]
options: _X=c
answer: "_X=a / _X=a"

[case]
makefile:

a: export override private foo bar
foo bar export override private: ; @echo $@
answer: "export
override
private
foo
bar"

[case]
makefile:

private = g
a: private = a
a: b
a b: ; @echo $@=$(private)
answer: "b=a
a=a"

[case]
makefile:

DEFS = FOO
all: bar1
bar1: private DEFS += 1
bar3: private DEFS += 3
bar1: bar2
bar2: bar3
bar1 bar2 bar3: ; @echo '$@: $(DEFS)'
answer: "bar3: FOO 3
bar2: FOO
bar1: FOO 1"

[case]
makefile:

IA = global
PA = global
PS = global
S = global
PS = global
SV = global
b%: IA += b%
b%: private PA += b%
b%: private PS = b%
bar: all
bar: IA += bar
bar: private PA += bar
bar: private PS = bar
a%: IA += a%
a%: private PA += a%
a%: private PS = a%
all: IA += all
all: private PA += all
all: private PS = all

bar all: ; @echo '$@: IA=$(IA)'; echo '$@: PA=$(PA)'; echo '$@: PS=$(PS)'
answer: "all: IA=global b% bar a% all
all: PA=global a% all
all: PS=all
bar: IA=global b% bar
bar: PA=global b% bar
bar: PS=bar"

[case]
makefile:

a: private export FOO := a
a: b
b: ; @#HELPER# env FOO
answer: "FOO=<unset>"

[case]
makefile:

a: private export FOO := a
a: b
b: FOO := b
b: ; @#HELPER# env FOO
answer: "FOO=<unset>"

[case]
makefile:

export FOO := g
a: private export FOO := a
a: b
b:
b: ; @#HELPER# env FOO
answer: "FOO=g"

[case]
makefile:

export FOO := g
a: private export FOO := a
a: b
b: FOO := b
b: ; @#HELPER# env FOO
answer: "FOO=b"

[case]
makefile:

private export FOO := g
a: private export FOO := a
a: b
b: FOO := b
b: ; @#HELPER# env FOO
answer: "FOO=<unset>"

[case]
makefile:

#TAB#private FOO = bar
all:;@echo hi
answer: "#MAKEFILE#:2: warning: directive lines cannot start with TAB
hi"

[case]
makefile:

#TAB#private#TAB#export FOO = bar
all:;@echo hi
answer: "#MAKEFILE#:2: warning: directive lines cannot start with TAB
hi"

[case]
makefile:

    private#TAB#export FOO = bar
all:;@echo hi
answer: "hi"
