#MAKE#: 'all' is up to date.

[case]
makefile:

hello: hello; @:
answer: "#MAKE#: circular hello <- hello dependency dropped"

[case]
makefile:

.WARNINGS = circular-dep:error
hello: hello; @:
answer: "#MAKE#: *** circular hello <- hello dependency detected.  Stop."
exit_code: 512

[case]
makefile:

.WARNINGS = circular-dep:warn
hello: hello; @:
answer: "#MAKE#: circular hello <- hello dependency dropped"

[case]
makefile:

.WARNINGS = circular-dep:ignore
hello: hello; @:
