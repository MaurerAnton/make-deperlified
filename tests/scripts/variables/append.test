
[case]
makefile:

# goal = phobos
# init = 
# target = 
# ga = 
# bovr = 
# yovr = 
# cmd = 
# env = 
# dashe = 

moon: hello=1
moon: override hello+=2



hello+=blue
hello+=yellow

satur%: override hello:=3
satur%: hello+=4

$(info $(hello))
phobos:; $(info $(hello))
mars: phobos; $(info $(hello))
saturn:; $(info $(hello))
options: phobos
answer: "blue yellow
blue yellow
#MAKE#: 'phobos' is up to date."

