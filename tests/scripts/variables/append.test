hello:=file
hello+=red
override hello+=blue
override hello+=yellow

satur%: override hello:=3
satur%: hello+=4

$(info $(hello))
phobos:; $(info $(hello))
mars: phobos; $(info $(hello))
saturn:; $(info $(hello))
options: phobos
answer: "file red blue yellow
