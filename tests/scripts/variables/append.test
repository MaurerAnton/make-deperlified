# goal = phobos
# init = 
# target = phobo%: 
# ga = 
# bovr = override 
# yovr = 
# cmd = hello=cmd
# env = 
# dashe = -e

moon: hello=1
moon: override hello+=2



phobo%: override hello+=blue
phobo%: hello+=yellow

satur%: override hello:=3
satur%: hello+=4

$(info $(hello))
phobos:; $(info $(hello))
mars: phobos; $(info $(hello))
saturn:; $(info $(hello))
options: -e hello=cmd phobos
answer: "cmd
cmd blue
#MAKE#: 'phobos' is up to date."

