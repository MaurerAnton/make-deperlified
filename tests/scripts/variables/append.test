moon: override hello+=2


hello+=red
override hello+=blue
override hello+=yellow

satur%: override hello:=3
satur%: hello+=4

$(info $(hello))
phobos:; $(info $(hello))
mars: phobos; $(info $(hello))
saturn:; $(info $(hello))
options: -e hello:=cmd hello+=cmd2 mars
answer: "cmd cmd2 blue yellow
