# target = 
# ga = 
# bovr = override 
# yovr = override 
# cmd = hello=cmd
# env = env
# dashe = -e

moon: hello=1
moon: override hello+=2

hello:=file

override hello+=blue
override hello+=yellow

satur%: override hello:=3
satur%: hello+=4

$(info $(hello))
phobos:; $(info $(hello))
mars: phobos; $(info $(hello))
saturn:; $(info $(hello))
options: -e hello=cmd phobos
answer: "cmd blue yellow
cmd blue yellow
#MAKE#: 'phobos' is up to date."

