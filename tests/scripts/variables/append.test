# init = hello:=file
# target = phobo%: 
# ga = 
# bovr = override 
# yovr = 
# cmd = 
# env = 
# dashe = 

moon: hello=1
moon: override hello+=2

phobo%: hello:=file

phobo%: override hello+=blue
phobo%: hello+=yellow

satur%: override hello:=3
satur%: hello+=4

$(info $(hello))
phobos:; $(info $(hello))
mars: phobos; $(info $(hello))
saturn:; $(info $(hello))
options: phobos
answer: "file blue
#MAKE#: 'phobos' is up to date."

