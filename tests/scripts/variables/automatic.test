# Converted from automatic
description: "Test automatic variable setting."

[setup]
touch: foo.x baz.z foo

[case]
makefile:

.SUFFIXES:
.SUFFIXES: .x .y .z
$(dir)/foo.x : baz.z $(dir)/bar.y baz.z
#TAB#@echo '$$@ = $@, $$(@D) = $(@D), $$(@F) = $(@F)'
#TAB#@echo '$$* = $*, $$(*D) = $(*D), $$(*F) = $(*F)'
#TAB#@echo '$$< = $<, $$(<D) = $(<D), $$(<F) = $(<F)'
#TAB#@echo '$$^ = $^, $$(^D) = $(^D), $$(^F) = $(^F)'
#TAB#@echo '$$+ = $+, $$(+D) = $(+D), $$(+F) = $(+F)'
#TAB#@echo '$$? = $?, $$(?D) = $(?D), $$(?F) = $(?F)'
#TAB#touch $@

$(dir)/bar.y baz.z : ; touch $@
options: dir=../tests
answer: "touch ../tests/bar.y
$@ = ../tests/foo.x, $(@D) = ../tests, $(@F) = foo.x
$* = ../tests/foo, $(*D) = ../tests, $(*F) = foo
$< = baz.z, $(<D) = ., $(<F) = baz.z
$^ = baz.z ../tests/bar.y, $(^D) = . ../tests, $(^F) = baz.z bar.y
$+ = baz.z ../tests/bar.y baz.z, $(+D) = . ../tests ., $(+F) = baz.z bar.y baz.z
$? = ../tests/bar.y, $(?D) = ../tests, $(?F) = bar.y
touch ../tests/foo.x"

[case]
makefile:

.SECONDEXPANSION:
.SUFFIXES:
.DEFAULT: ; @echo '$@'

$(dir)/foo $(dir)/bar: $@.x $$@.x $$$@.x $$$$@.x $$(@D).x $$(@F).x

$(dir)/x.z $(dir)/y.z: $(dir)/%.z : $@.% $$@.% $$$@.% $$$$@.% $$(@D).% $$(@F).%

