# Converted from define
description: "Test define/endef variable assignments."

[case]
makefile:

define multi
@echo hi
echo there
endef

all: ; $(multi)
answer:
hi
echo there
there

[case]
makefile:

FOO = foo

define multi =
echo hi
@echo $(FOO)
endef # this is the end

define simple :=
@echo $(FOO)
endef

define posix ::=
@echo $(FOO)
endef

append = @echo a

define append +=

@echo b
endef

define cond ?= # this is a conditional
@echo first
endef

define cond ?=
@echo second
endef

FOO = there

all: ; $(multi)
#TAB#$(simple)
#TAB#$(posix)
#TAB#$(append)
#TAB#$(cond)
answer:
echo hi
hi
there
foo
foo
a
b
first

[case]
makefile:

FOO = foo

define multi=
echo hi
@echo $(FOO)
endef # this is the end

define simple:=
@echo $(FOO)
endef

define posix::=
@echo $(FOO)
endef

define posixbsd:::=
@echo '$(FOO)$$bar'
endef

append = @echo a

define append+=

@echo b
endef

define cond?= # this is a conditional
@echo first
endef

define cond?=
@echo second
endef

FOO = there

all: ; $(multi)
#TAB#$(simple)
#TAB#$(posix)
#TAB#$(posixbsd)
#TAB#$(append)
#TAB#$(cond)
answer:
echo hi
hi
there
foo
foo
foo$bar
a
b
first

[case]
makefile:

FOO = foo
NAME = def
def =
ifdef BOGUS
 define  $(subst e,e,$(NAME))     =
  ifeq (1,1)
   FOO = bar
  endif
 endef
endif

$(eval $(def))
all: ; @echo $(FOO)
options: BOGUS=1
answer: "bar"

[case]
answer: "foo"

[case]
makefile:

define outer
 define inner
  A = B
 endef
endef

$(eval $(outer))

outer: ; @echo $(inner)
answer: "A = B"

[case]
makefile:

NAME =
define $(NAME)  =
ouch
endef
all: ; @echo ouch
answer: "#MAKEFILE#:3: *** empty variable name.  Stop."
exit_code: 512

[case]
makefile:

NAME =
define NAME = $(NAME)
ouch
endef
all: ; @echo ok
answer:
#MAKEFILE#:3: extraneous text after 'define' directive
ok

[case]
makefile:

NAME =
define NAME =
ouch
endef $(NAME)
all: ; @echo ok
answer:
#MAKEFILE#:5: extraneous text after 'endef' directive
ok

[case]
makefile:

NAME =
all: ; @echo ok
define NAME =
ouch
endef$(NAME)
answer: "#MAKEFILE#:4: *** missing 'endef', unterminated 'define'.  Stop."
exit_code: 512

