[case]
makefile:

define FOO
@echo hello
echo world
endef
define BAR
echo hello
echo world
endef

all: foo bar
foo: ; $(FOO)
bar: ; @$(BAR)
answer:
hello
echo world
world
hello
world

[case]
makefile:

define = define

$(define) : ;@echo $@

%:define

all: define foo

%.x : define

foo:;
answer: "define"

[case]
makefile:

#TAB#define foo
  @echo foo
endef

all:;$(foo)
answer:
#MAKEFILE#:2: warning: directive lines cannot start with TAB
foo

[case]
makefile:

foo = echo foo

define bar
#TAB#define foo
#TAB#  echo bar
#TAB#endef
endef

all:;@$(foo)
answer: "foo"

[case]
makefile:

foo = echo foo

define bar
#TAB#define foo
#TAB#  echo bar
#TAB#endef
endef

$(eval $(bar))

all:;@echo foo
answer:
#MAKEFILE#:10: warning: directive lines cannot start with TAB
#MAKEFILE#:10: *** missing 'endef', unterminated 'define'.  Stop.
exit_code: 512

