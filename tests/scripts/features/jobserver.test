# Converted from jobserver
description: "Test jobserver."
details: "These tests are ones that specifically are different when the jobserver feature is available. Most -j tests are the same whether or not jobserver is available, and those appear in the 'parallelism' test suite."

[case]
makefile:

SHOW = $(patsubst --jobserver-auth=%,--jobserver-auth=<auth>,$(MAKEFLAGS))
recurse: ; @echo $@: "/$(SHOW)/"; $(MAKE) -f #MAKEFILE# all
all:;@echo $@: "/$(SHOW)/"
options: -j2 --no-print-directory
answer:
recurse: /-j2 --jobserver-auth=<auth> --no-print-directory/
all: /-j2 --jobserver-auth=<auth> --no-print-directory/

[case]
makefile:

SHOW = $(patsubst --jobserver-auth=%,--jobserver-auth=<auth>,$(MAKEFLAGS))
recurse: ; @echo $@: "/$(SHOW)/"; $(MAKE) -f #MAKEFILE# all
all:;@echo $@: "/$(SHOW)/"
answer:
recurse: /-j2 --jobserver-auth=<auth> --no-print-directory/
all: /-j2 --jobserver-auth=<auth> --no-print-directory/

[case]
makefile:

SHOW = $(patsubst --jobserver-auth=%,--jobserver-auth=<auth>,$(MAKEFLAGS))
recurse: ; @echo $@: "/$(SHOW)/"; $(MAKE) -j3 -f #MAKEFILE# recurse2
recurse2: ; @echo $@: "/$(SHOW)/"; $(MAKE) -f #MAKEFILE# all
all:;@echo $@: "/$(SHOW)/"
options: -j2 --no-print-directory
answer:
recurse: /-j2 --jobserver-auth=<auth> --no-print-directory/
#MAKE#[1]: warning: -j3 forced in submake: resetting jobserver mode
recurse2: /-j3 --jobserver-auth=<auth> --no-print-directory/
all: /-j3 --jobserver-auth=<auth> --no-print-directory/

[case]
makefile:

SHOW = $(patsubst --jobserver-auth=%,--jobserver-auth=<auth>,$(MAKEFLAGS))
recurse: ; @echo $@: "/$(SHOW)/"; $(MAKE) -j -f #MAKEFILE# recurse2
recurse2: ; @echo $@: "/$(SHOW)/"; $(MAKE) -f #MAKEFILE# all
all:;@echo $@: "/$(SHOW)/"
options: -j2 --no-print-directory
answer:
recurse: /-j2 --jobserver-auth=<auth> --no-print-directory/
#MAKE#[1]: warning: -j0 forced in submake: resetting jobserver mode
recurse2: /-j --no-print-directory/
all: /-j --no-print-directory/

[case]
makefile:

.RECIPEPREFIX = >
-include inc.mk
recur:
#> @echo 'MAKEFLAGS = $(MAKEFLAGS)'
> @rm -f inc.mk
> @$(MAKE) -j2 -f #MAKEFILE# all
all:
#> @echo 'MAKEFLAGS = $(MAKEFLAGS)'
> @echo $@
inc.mk:
#> @echo 'MAKEFLAGS = $(MAKEFLAGS)'
> @echo 'FOO = bar' > $@
options: --no-print-directory -j2
answer:
#MAKE#[1]: warning: -j2 forced in submake: resetting jobserver mode
all

[case]
makefile:

default: ; @ #MAKEPATH# -f Makefile2
options: --jobserver-style=pipe -j2 --no-print-directory
answer:
#MAKE#[1]: warning: jobserver unavailable: using -j1 (add '+' to parent make rule)
#MAKE#[1]: Nothing to be done for 'foo'.

[case]
makefile:

all: ; @$(MAKE) -C . -f #MAKEFILE# recurse -j1
recurse: ; @echo hi
options: -w -j2
answer:
#MAKE#: Entering directory '#PWD#'
#MAKE#[1]: Entering directory '#PWD#'
hi
#MAKE#[1]: Leaving directory '#PWD#'
#MAKE#: Leaving directory '#PWD#'

[case]
makefile:

all: ; @$(MAKE) -C . -f #MAKEFILE# recurse -j10
recurse: ; @echo hi
options: -w -j2
answer:
#MAKE#: Entering directory '#PWD#'
#MAKE#[1]: Entering directory '#PWD#'
#MAKE#[1]: warning: -j10 forced in submake: resetting jobserver mode
hi
#MAKE#[1]: Leaving directory '#PWD#'
#MAKE#: Leaving directory '#PWD#'

[case]
makefile:

all: a
all a: ; @echo $@
options: --jobserver-style=foo -j8
answer: "#MAKE#: *** unknown jobserver auth style 'foo'.  Stop."
exit_code: 512

[case]
makefile:

.RECIPEPREFIX := >
all:
> @echo $@ 1
> @echo $@ 2
> @$(MAKE) -f #MAKEFILE# recurse

recurse: ; @echo $@
options: --no-print-directory -j8
answer:
all 1
all 2
recurse

[case]
options: --no-print-directory --jobserver-style=pipe -j8
answer:
all 1
all 2
recurse

[case]
makefile:

.RECIPEPREFIX := >
all:
> @echo $@ 1
> @echo $@ 2
> @+#MAKEPATH# -f #MAKEFILE# recurse

recurse: ; @echo $@
options: --no-print-directory -j8
answer:
all 1
all 2
recurse

[case]
options: --no-print-directory --jobserver-style=pipe -j8
answer:
all 1
all 2
recurse

[case]
makefile:

all:; $(info hello, world)
    
options: -j688777
answer: "/requested job count \(688777\) is larger than system limit/"
exit_code: 512

[case]
makefile:

all:; $(info hello, world)
    
options: -j688777 --jobserver-style=pipe
answer: "/requested job count \(688777\) is larger than system limit/"
exit_code: 512
