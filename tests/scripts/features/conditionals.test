[case]
makefile:

ifeq (a, b)
#TAB## noop
else
#TAB#ifeq (a, b)
#TAB##TAB## noop
#TAB#endif
endif

all:
#TAB#@echo foo
answer:
#MAKEFILE#:5: warning: conditional directive lines cannot start with TAB
#MAKEFILE#:7: warning: conditional directive lines cannot start with TAB
foo

[case]
makefile:

all:

$(info hello)
ifdef blah
junk:
#TAB#else
else
endif
answer:
hello
#MAKEFILE#:7: warning: conditional directive lines cannot start with TAB
#MAKEFILE#:8: *** only one 'else' per conditional.  Stop.
exit_code: 512

