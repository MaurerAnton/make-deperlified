[case]
makefile:

ifeq ($(and a,b),)
endif
ifeq (${and a,b},)
endif
ifeq (${and $(x),${or $(z),${q}}},)
endif
ifeq (${and ),(},)
endif
ifeq ($(and },{),)
endif
# We can hide the comma in a variable
C = ,
ifeq ((and a$Cb),)
endif
all:;
answer: "#MAKE#: 'all' is up to date."

[case]
makefile:

ifeq ($,,)
$(info ok)
endif
all:;
answer:
ok
#MAKE#: 'all' is up to date.

[case]
makefile:

ifeq ((and a,b),)
endif
all:;
answer:
#MAKEFILE#:2: extraneous text after 'ifeq' directive
#MAKE#: 'all' is up to date.
