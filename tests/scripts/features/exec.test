
[case]
makefile:
# shbang=#!/bin/sh
# shell=
all:; @$(CMD)
options: CMD=./exec.cmd
answer: "hello, world"

[case]
makefile:
# shbang=#!/bin/sh
# shell=SHELL=/bin/sh
all:; @$(CMD)
options: SHELL=/bin/sh CMD=./exec.cmd.1
answer: "hello, world"

