# Converted from statipattrules
description: "Test handling of static pattern rules."
details: "The makefile created in this test has three targets. The filter command is used to get those target names ending in .o and statically creates a compile command with the target name and the target name with .c. It also does the same thing for another target filtered with .elc and creates a command to emacs a .el file"

[setup]
touch: bar.c lose.c foo.el hello.z a.src b.src

[case]
makefile:

files = foo.elc bar.o lose.o

$(filter %.o,$(files)): %.o: %.c ; @echo CC -c $(CFLAGS) $< -o $@

$(filter %.elc,$(files)): %.elc: %.el ; @echo emacs $<
answer: "CC -c bar.c -o bar.o"

[case]
options: lose.o
answer: "CC -c lose.c -o lose.o"

[case]
options: foo.elc
answer: "emacs foo.el"

[case]
makefile:

.DEFAULT: ; @echo $@
foo: foo%: % %.x % % % y.% % ; @echo $@
answer:
.x
y.
foo

[case]
makefile:

foo.x bar.x: %.x : ; @echo $@

answer: "foo.x"

[case]
makefile:

foo.bar:: %.bar: %.baz
foo.baz: ;@:

[case]
makefile:

.RECIPEPREFIX := >

all.foo.bar: %.foo.bar: %.one

all.foo.bar: %.bar: %.two

all.foo.bar:
>#TAB#@echo $*
>#TAB#@echo $^

.DEFAULT:;@:
answer:
all.foo
all.one all.foo.two

[case]
makefile:

.RECIPEPREFIX := >
.SECONDEXPANSION:

all.foo.bar: %.foo.bar: %.one $$*-one

all.foo.bar: %.bar: %.two $$*-two

all.foo.bar:
>#TAB#@echo $*
>#TAB#@echo $^

.DEFAULT:;@:
answer:
all.foo
all.one all-one all.foo.two all.foo-two

[case]
makefile:

hello.z: %.z: %.x ; @echo $@
%.x: ;
answer: "hello.z"

[case]
makefile:

hello.z: %.z: %.x test.x ; @echo $@
%.x: ;
answer: "hello.z"

[case]
makefile:

hello.z: %.z: %.x ; @echo $@
%.x: ;
unrelated: hello.x
answer: "hello.z"

[case]
makefile:

all: a.tgt b.tgt
a.tgt b.tgt:: %.tgt : %.src ; cp $< $@
answer:
