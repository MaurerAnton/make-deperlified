# Converted from output-sync
description: "Test --output-sync (-O) option."
details: "Test the synchronization of output from parallel jobs."

[case]
makefile:

all: make-foo make-bar

make-foo: ; $(MAKE) -C foo

make-bar: ; #HELPER# -q sleep 1 ; $(MAKE) -C bar
options: -j -Orecurse
answer: "#MAKEPATH# -C foo
#MAKE#[1]: Entering directory '#PWD#/foo'
foo: start
foo: end
#MAKE#[1]: Leaving directory '#PWD#/foo'
#HELPER# -q sleep 1 ; #MAKEPATH# -C bar
#MAKE#[1]: Entering directory '#PWD#/bar'
bar: start
bar: end
baz: start
baz: end
#MAKE#[1]: Leaving directory '#PWD#/bar'"

[case]
makefile:

x=1
$xMAKEFLAGS += --no-print-directory

all: make-foo make-bar

make-foo: ; $(MAKE) -C foo

make-bar: ; #HELPER# -q sleep 1 ; $(MAKE) -C bar
options: -j --output-sync=target
answer: "#MAKEPATH# -C foo
#HELPER# -q sleep 1 ; #MAKEPATH# -C bar
#MAKE#[1]: Entering directory '#PWD#/bar'
bar: start
bar: end
#MAKE#[1]: Leaving directory '#PWD#/bar'
#MAKE#[1]: Entering directory '#PWD#/foo'
foo: start
foo: end
#MAKE#[1]: Leaving directory '#PWD#/foo'
#MAKE#[1]: Entering directory '#PWD#/bar'
baz: start
baz: end
#MAKE#[1]: Leaving directory '#PWD#/bar'"

[case]
options: -j --output-sync=target x=
answer: "#MAKEPATH# -C foo
#HELPER# -q sleep 1 ; #MAKEPATH# -C bar
bar: start
bar: end
foo: start
foo: end
baz: start
baz: end"

[case]
makefile:

all: make-foo-fail make-bar-bar

make-foo-fail: ; $(MAKE) -C foo foo-fail

make-bar-bar: ; #HELPER# -q sleep 1 ; $(MAKE) -C bar bar
options: -j -O
answer: "#MAKEPATH# -C foo foo-fail
#HELPER# -q sleep 1 ; #MAKEPATH# -C bar bar
#MAKE#[1]: Entering directory '#PWD#/bar'
bar: start
bar: end
#MAKE#[1]: Leaving directory '#PWD#/bar'
#MAKE#[1]: Entering directory '#PWD#/foo'
foo-fail: start
foo-fail: end
#MAKE#[1]: *** [Makefile:23: foo-fail] Error 1
#MAKE#[1]: Leaving directory '#PWD#/foo'
#MAKE#: *** [#MAKEFILE#:4: make-foo-fail] Error 2"
exit_code: 512

[case]
makefile:

all: make-foo make-bar

make-foo: ; $(MAKE) -C foo foo-job

make-bar: ; #HELPER# -q sleep 1 ; $(MAKE) -C bar bar-job
options: -j --output-sync=line
answer: "#MAKEPATH# -C foo foo-job
#HELPER# -q sleep 1 ; #MAKEPATH# -C bar bar-job
#MAKE#[1]: Entering directory '#PWD#/foo'
foo: start
#MAKE#[1]: Leaving directory '#PWD#/foo'
#MAKE#[1]: Entering directory '#PWD#/bar'
bar: start
#MAKE#[1]: Leaving directory '#PWD#/bar'
#MAKE#[1]: Entering directory '#PWD#/bar'
bar: end
#MAKE#[1]: Leaving directory '#PWD#/bar'
#MAKE#[1]: Entering directory '#PWD#/foo'
foo: end
#MAKE#[1]: Leaving directory '#PWD#/foo'"

[case]
makefile:

all:
	@echo foo
	@+echo bar
options: -j -Oline
answer: "foo
bar"

[case]
options: -j -Otarget
answer: "foo
bar"

[case]
makefile:

all:
	@echo foobar
	true
options: -j -Oline
answer: "foobar
true"

[case]
options: -j -Otarget
answer: "foobar
true"

[case]
makefile:

all: ; @: $(shell echo foo 1>&2)
options: -w -Oline
answer: "#MAKE#: Entering directory '#PWD#'
foo
#MAKE#: Leaving directory '#PWD#'"

[case]
makefile:

$(shell echo foo 1>&2)
all: ; echo bar
options: -s -w -Otarget
answer: "#MAKE#: Entering directory '#PWD#'
foo
#MAKE#: Leaving directory '#PWD#'
#MAKE#: Entering directory '#PWD#'
bar
#MAKE#: Leaving directory '#PWD#'"

[case]
makefile:

all: t1 t2
t1: ; @$(MAKE) -f t001.mk
t2: ; @$(MAKE) -f t001.mk
options: -j -Oline
answer: "#MAKE#[1]: Entering directory '#PWD#'
d1 stderr
d1 stdout
#MAKE#[1]: Leaving directory '#PWD#'
#MAKE#[1]: Entering directory '#PWD#'
d2 stderr
d2 stdout
#MAKE#[1]: Leaving directory '#PWD#'"

[case]
makefile:

all: t1
t1: ; -@$(MAKE) -f t001.mk
options: -j -Oline
answer: "#MAKE#[1]: Entering directory '#PWD#'
d1 stderr
d1 stdout
t001.mk:3: *** d1 failed.  Stop.
#MAKE#[1]: Leaving directory '#PWD#'
#MAKE#: [#MAKEFILE#:3: t1] Error 2 (ignored)"

[case]
makefile:

foo: $(OBJS) ; echo $(or $(filter %.o,$^),$(error fail))
options: -O
answer: "#MAKEFILE#:2: *** fail.  Stop."
exit_code: 512

[case]
makefile:

all:: ; @./foo bar baz
options: -O
answer: "#MAKE#: ./foo: No such file or directory
#MAKE#: *** [#MAKEFILE#:2: all] Error 127"
exit_code: 512
