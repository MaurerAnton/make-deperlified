# Converted from vpathplus
description: "Tests the new VPATH+ functionality added in 3.76."

[setup]
touch: work//foo.d work//bar.d work//foo.c work//bar.c foo.b bar.d work//notarget.c notarget.b notarget.d work//inter.d inter.a work//inter.b

[case]
makefile:
VPATH = work/
.SUFFIXES: .a .b .c .d
.PHONY: general rename notarget intermediate

%.a:
%.b:
%.c:
%.d:

%.a : %.b ; cat $^ > $@
%.b : %.c ; cat $^ > $@ 2>/dev/null || exit 1
%.c :: %.d ; cat $^ > $@

# General testing info:

general: foo.b
foo.b: foo.c bar.c

# Rename testing info:

rename: $(VPATH)/foo.c foo.d

# Target not made testing info:

notarget: notarget.b
notarget.c: notarget.d ; -@echo "not creating $@ from $^"

# Intermediate files:

intermediate: inter.a
options: general
answer: "cat bar.d > bar.c
cat work/foo.c bar.c > foo.b 2>/dev/null || exit 1"

[case]
options: notarget
answer: "not creating notarget.c from notarget.d
cat notarget.c > notarget.b 2>/dev/null || exit 1
#MAKE#: *** [#MAKEFILE#:11: notarget.b] Error 1"
exit_code: 512

[case]
options: intermediate
answer: "cat work/inter.d > inter.c
cat inter.c > inter.b 2>/dev/null || exit 1
cat inter.b > inter.a
rm inter.b inter.c"

[case]
options: intermediate
answer: "cat work/inter.d > inter.c
cat inter.c > inter.b 2>/dev/null || exit 1
cat inter.b > inter.a
rm inter.c"
