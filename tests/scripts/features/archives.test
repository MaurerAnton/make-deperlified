# Converted from archives
description: "Test GNU Make's archive management features."
details: "This only works on systems that support it."

[setup]
touch: a1.o a2.o a3.o foo.vhd

[case]
makefile:
all: libxx.a(a1.o)
options: AR="ar"
answer:
ar -rv libxx.a a1.o
ar: creating libxx.a
ar: a1.o: No such file or directory

[case]
makefile:
all: libxx.a(a1.o a2.o)
options: AR="ar"
answer:
ar -rv libxx.a a2.o
ar: creating libxx.a
ar: a2.o: No such file or directory

[case]
options: AR="ar"
answer:
ar -rv libxx.a a1.o
ar: creating libxx.a
ar: a1.o: No such file or directory

[case]
makefile:
all: libxx.a(*.o)
options: AR="ar"
answer: "#MAKE#: Nothing to be done for 'all'."

[case]
options: AR="ar"
answer:
ar -rv libxx.a a1.o
ar: creating libxx.a
ar: a1.o: No such file or directory

[case]
makefile:
all: libxx.a(a3.o *.o)
options: AR="ar"
answer:
ar -rv libxx.a a3.o
ar: creating libxx.a
ar: a3.o: No such file or directory
ar -rv libxx.a a2.o
ar: creating libxx.a
ar: a2.o: No such file or directory

[case]
makefile:
all: libxx.a(  a3.o    *.o     )
options: AR="ar"
answer:
ar -rv libxx.a a2.o
ar: creating libxx.a
ar: a2.o: No such file or directory

[case]
makefile:

all: foo(bar).baz
foo(bar).baz: ; @echo '$@'
options: AR="ar"
answer: "foo(bar).baz"

[case]
makefile:

DIR = artest
vpath % $(DIR)
default: lib(foo)
(%): %.vhd ; @cd $(DIR) && touch $(*F) && $(AR) $(ARFLAGS) $@ $(*F) >/dev/null 2>&1 && rm $(*F)
.PHONY: default
options: AR="ar"

[case]
options: AR="ar"
answer: "#MAKE#: Nothing to be done for 'default'."
