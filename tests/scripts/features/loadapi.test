# Converted from loadapi
description: "Test the shared object load API."
details: "Verify the different aspects of the shared object API."

[setup]
touch: testapi.so

[case]
makefile:

EXPAND = expansion
all: ; @echo $(test-expand $$(EXPAND))
load testapi.so
answer: "expansion"

[case]
makefile:

load testapi.so
TEST = bye
ASSIGN = VAR = $(TEST) $(shell echo there)
$(test-eval $(value ASSIGN))
TEST = hi
all:;@echo '$(VAR)'
answer: "hi there"

[case]
makefile:

load testapi.so
TEST = hi
all:;@echo '$(test-noexpand $(TEST))'
answer: "$(TEST)"

