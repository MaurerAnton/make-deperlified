# Implicit rule test
%.d : %.e ; cp $< $@
%.e : %.f ; cp $< $@

foo.d: foo.e

# Explicit rule test
foo.c: foo.e ; cp $< $@
options: foo.c
answer: "#MAKE#: 'foo.c' is up to date."

[case]
