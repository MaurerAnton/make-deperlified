cp foo.e foo.c

[case]
makefile:
.SECONDARY:

final: intermediate
intermediate: source

final intermediate source: ; echo $< > $@
answer: "#MAKE#: 'final' is up to date."

[case]
makefile:

.PHONY: version
.SECONDARY:
version2: version ; @echo GOOD
all: version2
options: all
answer: "GOOD"

[case]
makefile:

%.c : %.b ; cp $< $@
%.b : %.a ; cp $< $@
all : 1.c 2.c
2.a: 1.c
options: -rR -j
answer:
cp 1.a 1.b
cp 1.b 1.c
cp 2.a 2.b
cp 2.b 2.c
rm 2.b 1.b

[case]
makefile:

.SECONDARY : test.1 test.2 test.3

test : test.4

%.4 : %.int %.3 ; touch $@

%.int : %.3 %.2 ; touch $@

%.3 : | %.2 ; touch $@

%.2 : %.1 ; touch $@

%.1 : %.0 ; touch $@
options: -rR -j 2
answer:
touch test.1
touch test.2
touch test.3
touch test.int
touch test.4
rm test.int

[case]
options: -rR -j 2
answer:
touch test.1
touch test.2
