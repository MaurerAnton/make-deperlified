# Converted from SILENT
description: "Test the special target .SILENT."

[case]
makefile:

.PHONY: M a b
M: a b
.SILENT : b
a b: ; echo $@
answer:
echo a
a
b

[case]
makefile:

.PHONY: M a b
M: a b
.SILENT:
