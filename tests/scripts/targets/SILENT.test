[case]
makefile:

.PHONY: M r a b
r: a b ; @$(MAKE) -f #MAKEFILE# M V=x
a b: ; echo $@

V =
$V.SILENT:
M: a b
options: --no-print-directory
answer:
a
b
echo a
a
echo b
