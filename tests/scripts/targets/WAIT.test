# Converted from WAIT
description: "Test the behaviour of the .WAIT target."

[case]
makefile:

all: .WAIT pre1 .WAIT pre2 | .WAIT pre3 ; @echo '<=$< ^=$^ ?=$? +=$+ |=$|'
pre1 pre2 pre3:;

# This is just here so we don't fail with older versions of make
.WAIT:
answer: "<=pre1 ^=pre1 pre2 ?=pre1 pre2 +=pre1 pre2 |=pre3"

[case]
makefile:

.SECONDEXPANSION:
all: $$(pre) ; @echo '<=$< ^=$^ ?=$? +=$+ |=$|'
pre1 pre2 pre3:;

pre = .WAIT pre1 .WAIT pre2 | .WAIT pre3
# This is just here so we don't fail with older versions of make
.WAIT:
answer: "<=pre1 ^=pre1 pre2 ?=pre1 pre2 +=pre1 pre2 |=pre3"

[case]
makefile:

all: pre
p% : .WAIT p%1 .WAIT p%2 | .WAIT p%3; @echo '<=$< ^=$^ ?=$? +=$+ |=$|'
pre1 pre2 pre3: ;

# This is just here so we don't fail with older versions of make
.WAIT:
answer: "<=pre1 ^=pre1 pre2 ?=pre1 pre2 +=pre1 pre2 |=pre3"

[case]
makefile:

all : pre1 .WAIT pre2
pre1: ; @#HELPER# -q out start-$@ sleep 1 out end-$@
pre2: ; @#HELPER# -q out $@

# This is just here so we don't fail with older versions of make
.WAIT:
options: -j10
answer: "start-pre1
end-pre1
pre2"

[case]
options: -j10 pre2
answer: "pre2"

[case]
makefile:

pre1: ; @#HELPER# -q out start-$@ sleep 1 out end-$@
pre2: ; @#HELPER# -q out $@

# This is just here so we don't fail with older versions of make
.WAIT:
options: -j10 pre1 .WAIT pre2
answer: "start-pre1
end-pre1
pre2"

[case]
makefile:

all : pre1 .WAIT .WAIT .WAIT pre2
pre1: ; @#HELPER# -q out start-$@ sleep 1 out end-$@
pre2: ; @#HELPER# -q out $@

# This is just here so we don't fail with older versions of make
.WAIT:
options: -j10
answer: "start-pre1
end-pre1
pre2"

[case]
makefile:

all : .WAIT pre1 .WAIT pre2 .WAIT
pre1: ; @#HELPER# -q out start-$@ sleep 1 out end-$@
pre2: ; @#HELPER# -q out $@

# This is just here so we don't fail with older versions of make
.WAIT:
options: -j10
answer: "start-pre1
end-pre1
pre2"

[case]
makefile:

all : .WAIT .WAIT .WAIT

# This is just here so we don't fail with older versions of make
.WAIT:
options: -j10
answer: "#MAKE#: Nothing to be done for 'all'."

[case]
makefile:

all:
options: -j10 .WAIT
answer: "#MAKE#: Nothing to be done for 'all'."

[case]
makefile:

all: hello.tsk .WAIT hello.tsk
hello.tsk:; $(info $@)
options: -j10
answer: "hello.tsk
#MAKE#: Nothing to be done for 'all'."

[case]
makefile:

hello.tsk:; $(info $@)
options: -j10 hello.tsk .WAIT hello.tsk
answer: "hello.tsk
#MAKE#: 'hello.tsk' is up to date.
#MAKE#: 'hello.tsk' is up to date."

[case]
makefile:

all : pre1 .WAIT pre2 pre3
pre1: ; @#HELPER# -q out start-$@ sleep 1 out end-$@
pre2: ; @#HELPER# -q out start-$@ file TWO wait THREE out end-$@
pre3: ; @#HELPER# -q wait TWO out $@ file THREE

# This is just here so we don't fail with older versions of make
.WAIT:
options: -j10
answer: "start-pre1
end-pre1
start-pre2
pre3
end-pre2"

[case]
makefile:

pre1: ; @#HELPER# -q out start-$@ sleep 1 out end-$@
pre2: ; @#HELPER# -q out start-$@ file TWO wait THREE out end-$@
pre3: ; @#HELPER# -q wait TWO out $@ file THREE

# This is just here so we don't fail with older versions of make
.WAIT:
options: -j10 pre1 .WAIT pre2 pre3
answer: "start-pre1
end-pre1
start-pre2
pre3
end-pre2"

[case]
makefile:

all : pre1 pre2 .WAIT post1 post2
pre1: ; @#HELPER# -q out start-$@ file PRE1 wait PRE2 sleep 1 out end-$@
pre2: ; @#HELPER# -q wait PRE1 out $@ file PRE2

post1: ; @#HELPER# -q wait POST2 out $@ file POST1
post2: ; @#HELPER# -q file POST2 wait POST1 out $@

# This is just here so we don't fail with older versions of make
.WAIT:
options: -j10
answer: "start-pre1
pre2
end-pre1
post1
post2"

