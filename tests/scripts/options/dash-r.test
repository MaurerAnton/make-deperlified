# Converted from dash-r
description: "Test removing default rules and variables"

[setup]
touch: xxx.c

[case]
options: -r COMPILE.c=echo xxx.o
answer: "#MAKE#: *** No rule to make target 'xxx.o'.  Stop."
exit_code: 512

[case]
makefile:

COMPILE.c = echo
MAKEFLAGS += -r
options: xxx.o
answer: "#MAKE#: *** No rule to make target 'xxx.o'.  Stop."
exit_code: 512

[case]
makefile:

all:;$(info CC='$(CC)')
options: -sR
answer: "CC=''"

[case]
makefile:

MAKEFLAGS += -R
all:;$(info CC='$(CC)')
options: -s
answer: "CC=''"

[case]
makefile:

MAKEFLAGS := -R
.PHONY: hello.c
all: hello.o
answer: "#MAKE#: *** No rule to make target 'hello.o', needed by 'all'.  Stop."
exit_code: 512

