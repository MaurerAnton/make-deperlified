# Converted from dash-e
description: "Test the -e (environment overrides) option"

[case]
makefile:

GOOGLE = bazzle
all:; @echo "$(GOOGLE)"
options: -e
answer: "boggle"

[case]
makefile:

$(info FOO [$(origin FOO)]: $(value FOO))
all: ;
recurse: ; @$(MAKE) -f #MAKEFILE#
options: -e --no-print-directory FOO=1 recurse
answer: "FOO [command line]: 1
FOO [command line]: 1
#MAKE#[1]: 'all' is up to date."

[case]
makefile:

.RECIPEPREFIX = >
$(info value=$(hello), origin=$(origin hello))
all:
> @echo "value=$(hello), origin=$(origin hello)"
> @$(MAKE) -C lib
.PHONY: lib all
options: -s
answer: "value=world, origin=environment
value=world, origin=environment
in submake value=world, origin=environment
value=world, origin=environment"

