# Converted from print-directory
description: "Test the -w option to GNU Make."

[case]
makefile:

all: ; @echo hi
answer: "hi"

[case]
options: -w
answer: "#MAKE#: Entering directory '#PWD#'
hi
#MAKE#: Leaving directory '#PWD#'"

[case]
options: -w --no-print-directory
answer: "hi"

[case]
options: --no-print-directory --print-directory
answer: "#MAKE#: Entering directory '#PWD#'
hi
#MAKE#: Leaving directory '#PWD#'"

[case]
makefile:

include foo
all: ;@:
foo: ; touch foo
answer: "touch foo"

[case]
options: -w
answer: "#MAKE#: Entering directory '#PWD#'
touch foo
#MAKE#: Leaving directory '#PWD#'"

[case]
options: -w --no-print-directory
answer: "touch foo"

[case]
options: --no-print-directory --print-directory
answer: "#MAKE#: Entering directory '#PWD#'
touch foo
#MAKE#: Leaving directory '#PWD#'"

[case]
makefile:

all: ;@$(MAKE) -f #MAKEFILE# recurse
recurse: ; @echo hi
answer: "#MAKE#[1]: Entering directory '#PWD#'
hi
#MAKE#[1]: Leaving directory '#PWD#'"

[case]
options: --no-print-directory
answer: "hi"

[case]
options: --no-print-directory -w
answer: "#MAKE#: Entering directory '#PWD#'
#MAKE#[1]: Entering directory '#PWD#'
hi
#MAKE#[1]: Leaving directory '#PWD#'
#MAKE#: Leaving directory '#PWD#'"

[case]
options: -w --no-print-directory
answer: "hi"
