[case]
makefile:

    slow: SHELL := echo
    slow: .SHELLFLAGS := hoho
    slow:; @foo bar
    
answer: "hoho foo bar"

[case]
makefile:

    slow: SHELL := echo hi
    slow: .SHELLFLAGS := ho ho
    slow:; @foo bar
    
answer: "hi ho ho foo bar"

[case]
makefile:

    slow: SHELL := echo hi
    slow: .SHELLFLAGS := 'ho;ho'
    slow:; @foo bar
    
answer: "hi ho;ho foo bar"
